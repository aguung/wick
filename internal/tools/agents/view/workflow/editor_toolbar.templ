package workflow

import "fmt"

// EditorToolbar is the header strip — workflow identity + action
// buttons. Theme tokens match the agents tab.
templ EditorToolbar(vm EditorVM) {
	<div class="flex items-center justify-between px-6 py-3 border-b border-white-300 dark:border-navy-600 bg-white-100 dark:bg-navy-700">
		<div class="flex items-center gap-3">
			<a href={ templ.SafeURL(vm.Base + "/workflows") } class="text-black-600 hover:text-black-900 dark:hover:text-white-100 transition-colors" title="Back to list">←</a>
			<h1 class="text-lg font-semibold text-black-900 dark:text-white-100">{ vm.Slug }</h1>
			if vm.Workflow.Enabled {
				<span class="inline-flex items-center gap-1 rounded-full bg-green-500/15 px-2 py-0.5 text-xs font-semibold text-green-700 dark:text-green-400">
					<span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>
					enabled
				</span>
			} else {
				<span class="inline-flex items-center gap-1 rounded-full bg-white-300 dark:bg-navy-600 px-2 py-0.5 text-xs font-semibold text-black-700 dark:text-black-600">
					<span class="h-1.5 w-1.5 rounded-full bg-black-500 dark:bg-black-600"></span>
					disabled
				</span>
			}
			if vm.Approved {
				<span class="inline-flex items-center rounded-full bg-blue-500/15 px-2 py-0.5 text-xs font-semibold text-blue-700 dark:text-blue-400">
					{ fmt.Sprintf("approved v%d", vm.Workflow.Version) }
				</span>
			}
		</div>
		<div class="flex gap-2 text-sm">
			<form method="POST" action={ templ.SafeURL(vm.Base + "/workflows/edit/" + vm.Slug + "/toggle") } class="inline">
				<button type="submit" class="rounded-lg border border-white-400 dark:border-navy-600 px-3 py-1.5 text-xs font-medium text-black-800 dark:text-black-600 hover:bg-white-200 dark:hover:bg-navy-800 transition-colors">
					if vm.Workflow.Enabled {
						Disable
					} else {
						Enable
					}
				</button>
			</form>
			<form method="POST" action={ templ.SafeURL(vm.Base + "/workflows/edit/" + vm.Slug + "/run") } class="inline">
				<button type="submit" class="rounded-lg bg-amber-500 px-3 py-1.5 text-xs font-medium text-white-100 hover:bg-amber-600 active:bg-amber-700 transition-colors">Run Now</button>
			</form>
			<form method="POST" action={ templ.SafeURL(vm.Base + "/workflows/edit/" + vm.Slug + "/save") } class="inline" id="save-form">
				<input type="hidden" name="body" id="save-body"/>
				<button type="submit" class="rounded-lg bg-green-500 px-3 py-1.5 text-xs font-medium text-white-100 hover:bg-green-600 active:bg-green-700 transition-colors">Save</button>
			</form>
			<form method="POST" action={ templ.SafeURL(vm.Base + "/workflows/edit/" + vm.Slug + "/delete") } onsubmit="return confirm('Delete this workflow?')" class="inline">
				<button type="submit" class="rounded-lg border border-rose-400 dark:border-rose-700 px-3 py-1.5 text-xs font-medium text-rose-600 dark:text-rose-400 hover:bg-rose-50 dark:hover:bg-rose-900/20 transition-colors">Delete</button>
			</form>
		</div>
	</div>
}
