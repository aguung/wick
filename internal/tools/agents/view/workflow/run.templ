package workflow

import (
	"fmt"

	wf "github.com/yogasw/wick/internal/agents/workflow"
	"github.com/yogasw/wick/internal/tools/agents/view"
)

// Run renders the run-detail page — state header + events.jsonl
// timeline. Reached from the bottom-pane Runs tab in the editor.
templ Run(vm RunVM) {
	@view.AgentsLayout(vm.Layout) {
		@Shell(vm.Base)
		<div class="max-w-5xl mx-auto px-6 py-10 wf-shell">
			<div class="mb-6">
				<a href={ templ.SafeURL(vm.Base + "/workflows/edit/" + vm.Slug) } class="text-sm text-slate-500 hover:text-slate-800">← { vm.Slug } editor</a>
				<h1 class="mt-1 text-2xl font-bold tracking-tight text-slate-900 dark:text-white-100">Run { vm.RunID }</h1>
				<p class="mt-1 text-xs wf-mono text-slate-500">
					status: <span class={ runStatusClass(vm.State.Status) }>{ vm.State.Status }</span>
					·
					{ fmt.Sprintf("%d completed", len(vm.State.Completed)) }
				</p>
			</div>
			@runEventsTable(vm.Events)
		</div>
	}
}

templ runEventsTable(events []wf.RunEvent) {
	<div class="rounded-xl border border-slate-200 bg-white shadow-sm overflow-hidden">
		<div class="border-b border-slate-200 bg-slate-50 px-4 py-2 text-xs font-semibold uppercase tracking-wider text-slate-500">Events timeline</div>
		if len(events) == 0 {
			<p class="p-6 text-sm text-slate-500">No events recorded.</p>
		} else {
			<ol class="divide-y divide-slate-100 wf-mono text-xs">
				for _, ev := range events {
					<li class="flex items-baseline gap-3 px-4 py-2">
						<span class="text-slate-400">{ ev.TS.Format("15:04:05.000") }</span>
						<span class="font-semibold text-slate-900">{ ev.Event }</span>
						if ev.Node != "" {
							<span class="text-emerald-700">{ ev.Node }</span>
						}
						if ev.Case != "" {
							<span class="text-amber-700">case={ ev.Case }</span>
						}
					</li>
				}
			</ol>
		}
	</div>
}
